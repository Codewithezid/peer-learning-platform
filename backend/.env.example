PORT=5000
FRONTEND_URL=http://localhost:3000
# Optional comma-separated list for multiple frontends (Vercel preview + production, etc.)
FRONTEND_URLS=http://localhost:3000,https://your-frontend.vercel.app
# Comma-separated Supabase user IDs who can access /admin APIs
ADMIN_USER_IDS=

# Supabase (required)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI provider (required for /ai endpoints)
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODEL=mistral-small-latest

# Optional semantic AI microservice (FastAPI + sentence-transformers)
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_TIMEOUT_MS=8000

# Optional Supabase Storage buckets for uploads
SUPABASE_AVATAR_BUCKET=avatars
SUPABASE_RESOURCE_BUCKET=resource-files
